PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/smart-gym
JWT_SECRET=change-me
JWT_EXPIRE=7d
FRONTEND_URL=http://localhost:5173

# Optional: “today” for locking past schedules uses the server’s local calendar (Node/OS).
# On cloud hosts that default to UTC, set your gym’s timezone so admin rules match local dates, e.g.:
# TZ=Asia/Colombo

GYM_MAX_BOOKINGS_PER_DAY=2
GYM_BOOKING_DEADLINE_HOURS=2
GYM_MIN_GAP_MINUTES=121
GYM_REMINDER_MINUTES=60
GYM_CHANGE_DEADLINE_MINUTES=60

# Booking confirmation email: without SMTP below, NOTHING is delivered to Gmail — only a preview in the
# backend terminal (unless NODE_ENV=production|test and BOOKING_EMAIL_LOG_PREVIEW is not true).
BOOKING_EMAIL_LOG_PREVIEW=true

# SMTP — required for real inbox delivery (e.g. Gmail: Google Account → Security → 2-Step Verification
# → App passwords → generate, then use that 16-char value as SMTP_PASS).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your.address@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# MAIL_FROM="Smart Gym <your.address@gmail.com>"
