PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/smart-gym
JWT_SECRET=change-me
JWT_EXPIRE=7d
FRONTEND_URL=http://localhost:5173

GYM_MAX_BOOKINGS_PER_DAY=2
GYM_BOOKING_DEADLINE_HOURS=2
GYM_MIN_GAP_MINUTES=121
GYM_REMINDER_MINUTES=60
GYM_CHANGE_DEADLINE_MINUTES=60

# Gym booking confirmation email (optional). If unset, development logs an email preview to the console.
BOOKING_EMAIL_LOG_PREVIEW=true

# SMTP (e.g. Gmail app password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM="Smart Gym <you@gmail.com>"
